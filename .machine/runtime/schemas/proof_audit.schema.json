{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "gaps"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "summary": {
      "type": "string"
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "kind", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["medium", "high"]
          },
          "kind": {
            "type": "string",
            "enum": ["matrix_gap", "state_gap", "proof_gap", "scope_gap"]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
